# Copy to .env and adjust values.
# Generate with: openssl rand -hex 32
FAILSAFE_JWT_SECRET=change-me

# Separate key for encrypting stored TOTP secrets (recommended in production).
# Generate with: openssl rand -hex 32
# FAILSAFE_ENCRYPTION_KEY=

# Server listen address (use one style):
# FAILSAFE_LISTEN=0.0.0.0:8080
FAILSAFE_LISTEN_HOST=127.0.0.1
FAILSAFE_LISTEN_PORT=8080

# Daemon: registration server URL (also set in ~/.config/failsafe/config.toml)
# FAILSAFE_SERVER_URL=http://192.168.1.10:8080

# FAILSAFE_DB_URL=sqlite:///path/to/failsafe.db?mode=rwc
# FAILSAFE_SKIP_WEB_BUILD=1
# FAILSAFE_DEBUG_SEND=1
# RUST_LOG=info,failsafe_server=debug
