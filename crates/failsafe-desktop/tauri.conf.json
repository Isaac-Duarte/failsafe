{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Failsafe",
  "version": "0.1.0",
  "identifier": "dev.failsafe.desktop",
  "build": {
    "beforeDevCommand": "npm run dev --prefix ../../failsafe-desktop-ui",
    "devUrl": "http://localhost:5174",
    "beforeBuildCommand": "npm run build --prefix ../../failsafe-desktop-ui",
    "frontendDist": "../../failsafe-desktop-ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Failsafe",
        "width": 1100,
        "height": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
